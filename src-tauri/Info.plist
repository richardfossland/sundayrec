<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<!--
  macOS privacy usage descriptions (TCC).

  SundayRec captures the microphone (cpal VU metering + ffmpeg avfoundation
  audio) and the camera (ffmpeg avfoundation video preview + recording). On
  macOS the OS *kills the app at first capture* if these strings are absent, so
  they are a hard prerequisite for any smoke test — see docs/SMOKE-TEST.md.

  Tauri 2 merges this file into the running app for BOTH `tauri dev` and
  `tauri build` on macOS (it is read from `src-tauri/Info.plist`). Keep it
  minimal: only the keys we actually need.
-->
<plist version="1.0">
  <dict>
    <key>NSMicrophoneUsageDescription</key>
    <string>SundayRec records the microphone so you can capture the audio of your church service.</string>
    <key>NSCameraUsageDescription</key>
    <string>SundayRec uses the camera to preview and record the video of your church service.</string>
    <!--
      PU-2 deep-link: register the `sundayrec://` URL scheme so macOS routes
      `sundayrec://…` links (OAuth / Plan import) back into the app. The Rust
      handler (`tauri_plugin_deep_link::on_open_url` → `tray::dispatch_deep_link`
      in src-tauri/src/lib.rs) is gated behind the default-off `tray` feature,
      which release builds include. Mirrors `plugins.deep-link.desktop.schemes`
      in tauri.conf.json. GUI-UNVERIFIED — confirm routing at rig-test.
    -->
    <key>CFBundleURLTypes</key>
    <array>
      <dict>
        <key>CFBundleURLName</key>
        <string>no.sundayrec.app</string>
        <key>CFBundleURLSchemes</key>
        <array>
          <string>sundayrec</string>
        </array>
      </dict>
    </array>
  </dict>
</plist>
