{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "SundayRec",
  "version": "0.4.0",
  "identifier": "no.sundayrec.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "SundayRec",
        "hiddenTitle": true,
        "width": 1180,
        "height": 760,
        "minWidth": 960,
        "minHeight": 640,
        "titleBarStyle": "Overlay"
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data: blob: asset: http://asset.localhost https://asset.localhost; media-src 'self' blob: asset: http://asset.localhost https://asset.localhost; connect-src 'self' ipc: http://ipc.localhost",
      "devCsp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data: blob: asset: http://asset.localhost https://asset.localhost; media-src 'self' blob: asset: http://asset.localhost https://asset.localhost; connect-src 'self' ipc: http://ipc.localhost ws://localhost:1420",
      "assetProtocol": {
        "enable": true,
        "scope": {
          "allow": [
            "$DOCUMENT/**",
            "$DOWNLOAD/**",
            "$VIDEO/**",
            "$AUDIO/**",
            "$DESKTOP/**",
            "$APPDATA/**",
            "$APPLOCALDATA/**"
          ],
          "deny": [
            "$HOME/.ssh/**",
            "$HOME/.aws/**",
            "$HOME/.gnupg/**",
            "$HOME/.netrc",
            "$HOME/.config/gh/**"
          ]
        }
      }
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": "all",
    "externalBin": ["binaries/ffmpeg", "binaries/ffprobe"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "entitlements": "Entitlements.plist",
      "minimumSystemVersion": "10.15"
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDE3OUFERDhFRjRBMjA4NEYKUldSUENLTDBqdDJhRngwKzNYcDlZdXprTllWdEpjWlZVZnBrbWkvK2JXNkdNRFFScWdOcU50UHkK",
      "endpoints": [
        "https://github.com/richardfossland/sundayrec/releases/latest/download/latest.json"
      ]
    }
  }
}
