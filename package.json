{
  "name": "sundayrec",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "ffmpeg": "node scripts/fetch-ffmpeg.mjs",
    "predev": "node scripts/fetch-ffmpeg.mjs",
    "dev": "vite",
    "pretauri": "node scripts/fetch-ffmpeg.mjs",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "tauri": "tauri",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:rust": "cargo test --workspace",
    "lint:rust": "cargo clippy --workspace --all-targets -- -D warnings",
    "fmt:rust": "cargo fmt --all",
    "bindings": "cargo test export_bindings --workspace",
    "fetch-ffmpeg": "node scripts/fetch-ffmpeg.mjs",
    "check": "npm run lint && npm run typecheck && npm run test && npm run lint:rust && npm run test:rust",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{ts,tsx,js,css,json,md}": "prettier --write",
    "*.{ts,tsx}": "eslint --fix"
  },
  "dependencies": {
    "@tanstack/react-query": "^5.100.14",
    "@tauri-apps/api": "^2",
    "@tauri-apps/plugin-dialog": "^2.7.1",
    "@tauri-apps/plugin-opener": "^2",
    "@tauri-apps/plugin-process": "^2",
    "i18next": "^26.3.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-i18next": "^17.0.8"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.0.1",
    "@commitlint/config-conventional": "^21.0.1",
    "@eslint/js": "^10.0.1",
    "@ffprobe-installer/ffprobe": "^2.1.2",
    "@tailwindcss/vite": "^4.3.0",
    "@tauri-apps/cli": "^2",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^25.9.1",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@vitejs/plugin-react": "^4.6.0",
    "eslint": "^10.4.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "ffmpeg-static": "^5.3.0",
    "globals": "^17.6.0",
    "husky": "^9.1.7",
    "jsdom": "^29.1.1",
    "lint-staged": "^17.0.5",
    "prettier": "^3.8.3",
    "tailwindcss": "^4.3.0",
    "typescript": "~5.8.3",
    "typescript-eslint": "^8.60.0",
    "vite": "^7.0.4",
    "vitest": "^4.1.7"
  }
}
