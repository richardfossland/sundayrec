{
  "name": "sundayrec",
  "private": true,
  "version": "0.2.0",
  "type": "module",
  "scripts": {
    "ffmpeg": "node scripts/fetch-ffmpeg.mjs",
    "predev": "node scripts/fetch-ffmpeg.mjs",
    "dev": "vite",
    "pretauri": "node scripts/fetch-ffmpeg.mjs",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "tauri": "tauri",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "tsc --noEmit",
    "test:rust": "cargo test --workspace",
    "lint:rust": "cargo clippy --workspace --all-targets -- -D warnings",
    "fmt:rust": "cargo fmt --all",
    "bindings": "cargo test export_bindings --workspace && node scripts/fix-bindings-imports.mjs",
    "fetch-ffmpeg": "node scripts/fetch-ffmpeg.mjs",
    "check": "npm run format:check && npm run lint && npm run typecheck && npm run lint:rust && npm run test:rust",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{ts,tsx,js,css,json,md}": "prettier --write",
    "*.{ts,tsx}": "eslint --fix"
  },
  "dependencies": {
    "@tauri-apps/api": "^2",
    "@tauri-apps/plugin-dialog": "^2.7.1",
    "@tauri-apps/plugin-opener": "^2",
    "@tauri-apps/plugin-process": "^2"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.0.1",
    "@commitlint/config-conventional": "^21.0.1",
    "@eslint/js": "^10.0.1",
    "@ffprobe-installer/ffprobe": "^2.1.2",
    "@tauri-apps/cli": "^2",
    "@types/node": "^25.9.1",
    "eslint": "^10.4.0",
    "eslint-config-prettier": "^10.1.8",
    "ffmpeg-static": "^5.3.0",
    "globals": "^17.6.0",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.5",
    "prettier": "^3.8.3",
    "typescript": "~5.8.3",
    "typescript-eslint": "^8.60.0",
    "vite": "^7.0.4"
  }
}
