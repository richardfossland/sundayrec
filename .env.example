# Copy this file to .env and fill in your credentials
# .env is gitignored — never commit it

# ── Apple code-signing (Mac builds only) ──────────────────────────────────────

# Your Apple ID (used for notarization)
APPLE_ID=you@example.com

# App-specific password: go to appleid.apple.com → Sign In → Security → App-Specific Passwords
# Generate one named "SundayRec Build" and paste it here
APPLE_APP_SPECIFIC_PASSWORD=xxxx-xxxx-xxxx-xxxx

# Apple Developer Team ID (10-character code, find it at developer.apple.com → Membership)
APPLE_TEAM_ID=XXXXXXXXXX

# SHA1 of the "Developer ID Application" certificate in your keychain
# Run: security find-identity -v -p codesigning | grep "Developer ID Application"
CSC_IDENTITY=0000000000000000000000000000000000000000

# ── Cloud OAuth client IDs (baked into the build via electron-vite) ───────────
#
# These are public identifiers, not secrets, but should still be loaded per-build
# so forks can register their own apps. PKCE protects against confused-deputy
# attacks; no client_secret is sent from the desktop app.

# Google Drive:
#   https://console.cloud.google.com → Create project → APIs & Services → Credentials
#   → Create OAuth 2.0 Client ID → Desktop app → copy Client ID and Client Secret
#   (Google requires client_secret in token exchange for Desktop apps even with PKCE)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Dropbox:
#   https://www.dropbox.com/developers/apps → Create app → Files.content.write scope
#   → Settings → Redirect URIs: add "sundayrec://oauth/dropbox" → copy App key
DROPBOX_APP_KEY=

# Microsoft OneDrive:
#   https://portal.azure.com → App registrations → New registration
#   → Add redirect URI: "sundayrec://oauth/onedrive" (Mobile/desktop) → copy Application (client) ID
ONEDRIVE_CLIENT_ID=
